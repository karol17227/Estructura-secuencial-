Algoritmo UsoFunciones
	
	Definir num, seno, coseno, tangente Como Real
	Definir raz, logaritmoNatural, logaritmo10 Como Real
	
	Escribir "Ingrese un número:"
	Leer num
	
	seno             <- sen(num)
	coseno           <- cos(num)
	tangente         <- tan(num)
	raz              <- rc(num)
	logaritmoNatural <- ln(num)
	logaritmo10      <- ln(num) / ln(10)
	
	Escribir "Del número: ", num
	Escribir "Su seno es: ", seno
	Escribir "Su coseno es: ", coseno
	Escribir "Su tangente es: ", tangente
	Escribir "Su raíz cuadrada es: ", raz
	Escribir "Su logaritmo natural es: ", logaritmoNatural
	Escribir "Su logaritmo en base 10 es: ", logaritmo10
	
FinAlgoritmo
