Algoritmo CDT
	
	Definir cantidad, porcentajeInteres, periodo Como Real
	Definir valorIntereses, impuesto, totalRetirar Como Real
	
	Escribir "Ingrese la cantidad invertida:"
	Leer cantidad
	
	Escribir "Ingrese el porcentaje de interés:"
	Leer porcentajeInteres
	
	Escribir "Ingrese el periodo en días:"
	Leer periodo
	
	valorIntereses = (cantidad * porcentajeInteres * periodo) / 360
	
	impuesto = valorIntereses * 0.07
	
	totalRetirar = cantidad + valorIntereses - impuesto
	
	Escribir "Valor de intereses ganados: ", valorIntereses
	Escribir "Impuesto de retención (7%): ", impuesto
	Escribir "Total a retirar: ", totalRetirar
	
FinAlgoritmo
